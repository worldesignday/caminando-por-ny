# Copia este archivo a .env.local y rellena los valores. NUNCA subas .env.local a git.

# Clave de Google Maps (Directions API) — solo para el script de datos offline
# (scripts/directions/compute.py). No se usa en el cliente.
GOOGLE_MAPS_API_KEY=

# Token público de MapLibre/Mapbox para los mapas interactivos (Fase 3).
# Si usas MapLibre con tiles abiertos, puede quedar vacío.
NEXT_PUBLIC_MAP_TILES_URL=
