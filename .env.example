# Copia este archivo a .env.local y rellena los valores. NUNCA subas .env.local a git.

# --- Servidor / offline (NO se exponen al cliente) ---
# Clave de Google Maps (Directions API) para los scripts de datos offline
# (scripts/directions/*.py: tiempos y polilíneas del recorrido). No se usa en el cliente.
GOOGLE_MAPS_API_KEY=

# --- Cliente (se exponen al navegador; RESTRINGIR por dominio en Google Cloud) ---
# Clave de "Maps JavaScript API" para el mapa interactivo. Debe estar restringida por
# referrer HTTP a tu dominio de Vercel + localhost, y limitada a Maps JavaScript API.
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# Map ID (tipo Vector) para los marcadores avanzados / estilo del mapa.
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=
